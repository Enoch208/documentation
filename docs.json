{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Backstop",
  "colors": {
    "primary": "#2563eb",
    "light": "#60a5fa",
    "dark": "#2563eb"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "pages": [
      {
        "group": "Overview",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "How it works",
        "pages": ["architecture", "guardrails", "resilience", "receipt"]
      },
      {
        "group": "Platform & deployment",
        "pages": ["platform", "deploy"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Enoch208/Backstop",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Enoch208/Backstop"
      }
    ],
    "primary": {
      "type": "button",
      "label": "View on GitHub",
      "href": "https://github.com/Enoch208/Backstop"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Enoch208/Backstop"
    }
  }
}
